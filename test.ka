// ==========================================
// OFFICIAL KA LANGUAGE FEATURE SHOWCASE FILE
// ==========================================

// Feature 1: Core Output Engine & Fast Math Calculations
say("--- 1. Testing Math Engine ---")
say(((24+32)*2)/2)
say("Executed successfully!")

// Feature 2: Clean Timing Operations (Pausing execution)
say("--- 2. Testing System Delays ---")
say("Waiting for 2 seconds to showcase processor throttling...")
wait(2)
say("Delay sequence complete.")

// Feature 3: Interactive System Prompts (Pauses until user presses Enter)
say("--- 3. Testing Interactive Prompts ---")
ask("System paused. Press ENTER to verify logic block capabilities: ")

// Feature 4: Conditional Logic Blocks (IF Statements)
say("--- 4. Testing Boolean Logic Gates ---")
if 10 > 5 {
    say("SUCCESS: The system evaluated '10 > 5' as True and entered this block.")
}

if 2 == 9 {
    say("FAILURE: This line should never print because '2 == 9' is False.")
}

// Feature 5: Loop Architecture (WHILE Loops)
say("--- 5. Testing Infinite Loop Prevention ---")
while 1 == 0 {
    say("FAILURE: This loop block should be instantly bypassed.")
}
say("SUCCESS: The loop was safely bypassed because the evaluation condition was False.")

// Feature 6: Runtime Terminal Protocols (Early Termination)
say("--- 6. Testing Early Exit Protocol ---")
say("Shutting down the language compiler safely now...")
exit()

// The system will stop completely at the exit() statement. 
// The line below serves to verify that the early shutdown works.
say("CRITICAL FAILURE: If you see this message, the exit() command failed!")
