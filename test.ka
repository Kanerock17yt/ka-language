// KA Language Extended Feature Showcase
say("Starting KA test sequence...")

set("greeting", "Hello KA user")
set("a", 5)
set("b", 10)

say("{greeting}")
say(a + b)

if a < b {
    say("{a} is less than {b}!")
}

set("counter", 1)
while counter <= 3 {
    say("Loop iteration {counter}")
    set("counter", counter + 1)
}

ask("Press ENTER to finish the KA test.")
say("KA test completed.")

exit(1)
say("You chouldn't be able to see this message unless there is a bug in the code!")
